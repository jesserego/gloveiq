{
  "name": "@gloveiq/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "npm run prisma:generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(optional)\"",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "sql:deploy": "node ./scripts/applySqlMigrations.mjs",
    "db:deploy": "npm run prisma:deploy && npm run sql:deploy",
    "library:ingest:db": "node ./scripts/libraryIngestToDb.mjs",
    "library:retry-images": "node ./scripts/retryFailedLibraryImages.mjs",
    "ebay:sync": "tsx ./scripts/ebaySync.ts",
    "market:recompute": "tsx ./scripts/recomputeGloveMarketSummaries.ts",
    "market:refresh": "tsx ./scripts/ebaySync.ts && tsx ./scripts/recomputeGloveMarketSummaries.ts",
    "contract:check": "tsx scripts/checkContracts.ts",
    "test:contracts": "tsx --test tests/contracts/*.test.ts",
    "ci:contracts": "npm run contract:check && npm run test:contracts",
    "library:validate": "python3 ../../scrapers/jbg/validate_library_xlsx.py",
    "library:ingest": "python3 ../../scrapers/jbg/run_gloveiq_pipeline.py --library-only"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@gloveiq/shared": "0.1.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.12",
    "prisma": "^6.16.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
